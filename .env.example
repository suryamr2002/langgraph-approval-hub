# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API

# Your Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — keep secret, used server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (e.g. https://your-app.vercel.app)
# Used for internal API calls during server-side rendering
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret token that your agents use to authenticate with /api/interrupt
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_TOKEN=your-secret-token-here

# ─── Live mode ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_MODE controls whether approve/reject is enabled:
#
# Not set or "false" (default) = read-only mode:
#   - "Read-only demo" banner shown to visitors
#   - Approve/Reject buttons disabled in UI
#   - /api/decide blocked server-side (DevTools bypass also blocked)
#
# "true" = live mode:
#   - Full approve/reject functionality enabled
#   - Use for your own real deployment or video recording
NEXT_PUBLIC_DEMO_MODE=false

# ─── Cron (optional) ──────────────────────────────────────────────────────────
# Secret for Vercel Cron to authenticate with /api/demo/seed
# Only needed if NEXT_PUBLIC_DEMO_MODE=true and you want daily auto-reset
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=your-cron-secret-here

# ─── Notifications (optional) ────────────────────────────────────────────────
# Resend API key for email notifications
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# Resend sender address (must be verified in your Resend account)
RESEND_FROM=approvals@yourdomain.com

# Slack webhook URL for Slack notifications
# Get from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
